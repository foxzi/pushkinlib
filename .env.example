# ============================================================
# Pushkinlib — пример конфигурации
# Скопируйте этот файл: cp .env.example .env
# Docker Compose автоматически подхватывает .env из корня проекта
# ============================================================

# === Пути к библиотеке (Docker) ===
# Путь на хосте к папке с книгами (монтируется в контейнер как /data/books)
LIBRARY_PATH=./books
# Имя файла индекса INPX внутри папки с книгами
INPX_FILE=test_library.inpx

# === Сервер ===
PORT=9090
CATALOG_TITLE=Pushkinlib
PAGE_SIZE=30
LOG_LEVEL=info
# Публичный URL сервиса (используется в OPDS-ссылках)
PUBLIC_BASE_URL=http://localhost:9090

# === Аутентификация ===
# Включить многопользовательскую авторизацию (по умолчанию выключена)
AUTH_ENABLED=false
# Логин администратора (создаётся автоматически при первом запуске)
ADMIN_USER=admin
# Пароль администратора — ОБЯЗАТЕЛЬНО замените при AUTH_ENABLED=true
ADMIN_PASS=admin123
# Секрет для подписи сессионных cookie (сгенерируйте: openssl rand -hex 32)
# Без явного значения сессии сбрасываются при перезапуске контейнера
SESSION_SECRET=change-me-in-production

# === Озвучка текста (TTS) ===
# API-ключ для TTS — один ключ используется и pushkinlib, и tts-server
TTS_API_KEY=sk-test-key-1
